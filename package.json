{
  "name": "cto-new",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "dev": "npx convex dev --once && concurrently -r npm:dev:web npm:dev:convex",
    "dev:web": "vite dev",
    "dev:ts": "tsc -b -w",
    "dev:convex": "npx convex dev",
    "build": "vite build && tsc --noEmit && (cp .output/public/wrangler.json ./wrangler.json || true)",
    "start": "node .output/public/_worker.js",
    "format": "prettier --write .",
    "lint": "tsc && eslint .  --ext ts,tsx --report-unused-disable-directives --max-warnings 0"
  },
  "dependencies": {
    "@auth/core": "0.37.4",
    "@convex-dev/agent": "^0.3.2",
    "@convex-dev/auth": "^0.0.90",
    "@convex-dev/react-query": "^0.1.0",
    "@openrouter/ai-sdk-provider": "^1.5.4",
    "@tanstack/react-query": "^5.90.20",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-with-query": "latest",
    "@tanstack/react-start": "latest",
    "convex": "^1.31.7",
    "jose": "^5.2.2",
    "lucide-react": "^0.475.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "resend": "^6.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.31.2",
    "@convex-dev/eslint-plugin": "^1.1.1",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/eslint-config": "^0.3.4",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.3",
    "concurrently": "~9.2.1",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.0.5"
  }
}
